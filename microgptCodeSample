import os
import math
import random
import urllib.request

random.seed(42)

# --- 1. Autograd Engine (Value Class) ---
class Value:
    __slots__ = ('data', 'grad', '_children', '_local_grads') 
    def __init__(self, data, children=(), local_grads=()):
        self.data = data   
        self.grad = 0                   
        self._children = children       
        self._local_grads = local_grads 
        
    def __add__(self, other):
        other = other if isinstance(other, Value) else Value(other)
        return Value(self.data + other.data, (self, other), (1, 1)) #[cite: 4]
        
    def __mul__(self, other):
        other = other if isinstance(other, Value) else Value(other)
        return Value(self.data * other.data, (self, other), (other.data, self.data))
        
    def __pow__(self, other): return Value(self.data**other, (self,), (other * self.data**(other-1),))
    def log(self): return Value(math.log(self.data), (self,), (1/self.data,))
    def exp(self): return Value(math.exp(self.data), (self,), (math.exp(self.data),))
    
    def gelu(self): # Integrated GELU implementation [cite: 5]
        c1, c2 = math.sqrt(2.0 / math.pi), 0.044715
        v = self.data
        t = math.tanh(c1 * (v + c2 * v**3))
        out = 0.5 * v * (1.0 + t)
        dt = 1.0 - t**2
        inner_grad = c1 * (1.0 + 3.0 * c2 * v**2)
        grad = 0.5 * (1.0 + t) + 0.5 * v * dt * inner_grad
        return Value(out, (self,), (grad,)) #[cite: 6]

    def __neg__(self): return self * -1
    def __radd__(self, other): return self + other
    def __sub__(self, other): return self + (-other)
    def __rmul__(self, other): return self * other
    def __truediv__(self, other): return self * other**-1

    def backward(self): # Topological sort for chain rule [cite: 8]
        topo, visited = [], set()
        def build_topo(v):
            if v not in visited:
                visited.add(v)
                for child in v._children: build_topo(child)
                topo.append(v)
        build_topo(self)
        self.grad = 1
        for v in reversed(topo):
            for child, local_grad in zip(v._children, v._local_grads):
                child.grad += local_grad * v.grad #[cite: 9]

# --- 2. Data Loading & Tokenizer ---
if not os.path.exists('input.txt'):
    names_url = 'https://raw.githubusercontent.com/karpathy/makemore/988aa59/names.txt'
    urllib.request.urlretrieve(names_url, 'input.txt')
docs = [line.strip() for line in open('input.txt') if line.strip()]
random.shuffle(docs)

uchars = sorted(set(''.join(docs))) #[cite: 2]
BOS = len(uchars) 
vocab_size = len(uchars) + 1 

# --- 3. Model Hyperparameters ---
n_layer, n_embd, block_size, n_head = 1, 16, 16, 4
head_dim = n_embd // n_head
lora_r, lora_alpha, n_experts = 2, 2, 2 #[cite: 11]

# --- 4. Initialization ---
matrix = lambda nout, nin, std=0.08: [[Value(random.gauss(0, std)) for _ in range(nin)] for _ in range(nout)]
matrix_zero = lambda nout, nin: [[Value(0.0) for _ in range(nin)] for _ in range(nout)]

state_dict = {'wte': matrix(vocab_size, n_embd), 'lm_head': matrix(vocab_size, n_embd)}
for i in range(n_layer):
    # Attention Weights (Base + LoRA) [cite: 10, 11]
    state_dict[f'l{i}.wq'] = matrix(n_embd, n_embd)
    state_dict[f'l{i}.wq_A'] = matrix(lora_r, n_embd)
    state_dict[f'l{i}.wq_B'] = matrix_zero(n_embd, lora_r)
    state_dict[f'l{i}.wk'] = matrix(n_embd, n_embd)
    state_dict[f'l{i}.wv'] = matrix(n_embd, n_embd)
    state_dict[f'l{i}.wv_A'] = matrix(lora_r, n_embd)
    state_dict[f'l{i}.wv_B'] = matrix_zero(n_embd, lora_r)
    state_dict[f'l{i}.wo'] = matrix(n_embd, n_embd)
    # Mixture of Experts Parameters [cite: 11]
    state_dict[f'l{i}.moe_router'] = matrix(n_experts, n_embd)
    for e in range(n_experts):
        state_dict[f'l{i}.exp{e}_fc1'] = matrix(4 * n_embd, n_embd)
        state_dict[f'l{i}.exp{e}_fc2'] = matrix(n_embd, 4 * n_embd)

# OPTIMIZATION: Trainable parameter selection
params = [p for k, mat in state_dict.items() for row in mat for p in row 
          if '_lora_' in k or 'moe' in k or 'expert' in k or 'wte' in k]

# --- 5. Component Functions ---
def linear(x, w): return [sum(wi * xi for wi, xi in zip(wo, x)) for wo in w]

def rmsnorm(x):
    ms = sum(xi * xi for xi in x) / len(x)
    scale = (ms + 1e-5) ** -0.5
    return [xi * scale for xi in x] #[cite: 13]

def apply_rope(vec, pos): # Rotary Position Embedding [cite: 14]
    out = []
    for j in range(0, len(vec), 2):
        theta = 10000.0 ** (-j / head_dim)
        m_theta = pos * theta
        c, s = math.cos(m_theta), math.sin(m_theta)
        v0, v1 = vec[j], vec[j+1]
        out.append(v0 * c - v1 * s)
        out.append(v0 * s + v1 * c)
    return out

# --- 6. Forward Pass (Integrated GPT) ---
def gpt(token_id, pos_id, keys, values):
    x = rmsnorm(state_dict['wte'][token_id])
    
    for li in range(n_layer):
        # 1) Multi-head Attention with LoRA [cite: 15, 16]
        x_res = x
        x = rmsnorm(x)
        
        # LoRA Query/Value calculation: Base + (A * B) * scale
        q_base = linear(x, state_dict[f'l{li}.wq'])
        q_lora = linear(linear(x, state_dict[f'l{li}.wq_A']), state_dict[f'l{li}.wq_B'])
        q = [qb + ql * (lora_alpha / lora_r) for qb, ql in zip(q_base, q_lora)]
        
        k = linear(x, state_dict[f'l{li}.wk'])
        
        v_base = linear(x, state_dict[f'l{li}.wv'])
        v_lora = linear(linear(x, state_dict[f'l{li}.wv_A']), state_dict[f'l{li}.wv_B'])
        v = [vb + vl * (lora_alpha / lora_r) for vb, vl in zip(v_base, v_lora)]
        
        keys[li].append(k); values[li].append(v)
        x_attn = []
        for h in range(n_head):
            hs = h * head_dim
            q_h = apply_rope(q[hs:hs+head_dim], pos_id) #[cite: 18]
            k_h = [apply_rope(ki[hs:hs+head_dim], t) for t, ki in enumerate(keys[li])]
            v_h = [vi[hs:hs+head_dim] for vi in values[li]]
            
            # Dot-product attention with scalling
            logits = [sum(q_h[j] * k_h[t][j] for j in range(head_dim)) / head_dim**0.5 for t in range(len(k_h))]
            exps = [(val - max(v.data for v in logits)).exp() for val in logits]
            weights = [e / sum(exps) for e in exps]
            x_attn.extend([sum(weights[t] * v_h[t][j] for t in range(len(v_h))) for j in range(head_dim)]) #[cite: 19]
            
        x = [a + b for a, b in zip(linear(x_attn, state_dict[f'l{li}.wo']), x_res)]
        
        # 2) Sparse MoE Block (Top-1 Optimization) [cite: 21]
        x_res = x
        x = rmsnorm(x)
        router_logits = linear(x, state_dict[f'l{li}.moe_router'])
        best_exp_idx = 0 if router_logits[0].data > router_logits[1].data else 1
        
        # Only compute the chosen expert
        h_expert = [hi.gelu() for hi in linear(x, state_dict[f'l{li}.exp{best_exp_idx}_fc1'])]
        e_out = linear(h_expert, state_dict[f'l{li}.exp{best_exp_idx}_fc2'])
        
        router_exps = [v.exp() for v in router_logits]
        prob = router_exps[best_exp_idx] / sum(router_exps)
        x = [a + b * prob for a, b in zip(x_res, e_out)]
        
    return linear(x, state_dict['lm_head'])

# --- 7. Training Loop (Adam Optimizer) ---
learning_rate, beta1, beta2, eps_adam = 0.01, 0.85, 0.99, 1e-8
m = [0.0] * len(params) 
v_adam = [0.0] * len(params) 

for step in range(1000):
    doc = docs[step % len(docs)]
    tokens = [BOS] + [uchars.index(ch) for ch in doc] + [BOS] #[cite: 23]
    n = min(block_size, len(tokens) - 1)
    
    keys, values = [[] for _ in range(n_layer)], [[] for _ in range(n_layer)]
    losses = []
    for pos_id in range(n):
        logits = gpt(tokens[pos_id], pos_id, keys, values)
        exps = [(val - max(v.data for v in logits)).exp() for val in logits]
        probs = [e / sum(exps) for e in exps]
        loss_t = -probs[tokens[pos_id + 1]].log() #[cite: 24]
        losses.append(loss_t)
    
    loss = (1 / n) * sum(losses)
    loss.backward()
    
    # Adam Update [cite: 25]
    lr_t = learning_rate * (1 - step / 1000)
    for i, p in enumerate(params):
        m[i] = beta1 * m[i] + (1 - beta1) * p.grad
        v_adam[i] = beta2 * v_adam[i] + (1 - beta2) * p.grad ** 2
        m_hat = m[i] / (1 - beta1 ** (step + 1))
        v_hat = v_adam[i] / (1 - beta2 ** (step + 1))
        p.data -= lr_t * m_hat / (v_hat ** 0.5 + eps_adam)
        p.grad = 0 #[cite: 26]
        
    print(f"step {step+1:4d} | loss {loss.data:.4f}", end='\r')
    print(f"step {step+1:4d} / {num_steps:4d} | loss {loss.data:.4f}", end='\r')
